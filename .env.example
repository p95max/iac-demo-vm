# Postgres
POSTGRES_DB=keycloak
POSTGRES_USER=keycloak
POSTGRES_PASSWORD=change_me

# Keycloak
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=change_me
KC_DB=postgres
KC_DB_URL_HOST=postgres
KC_DB_USERNAME=keycloak
KC_DB_PASSWORD=change_me

# Public URLs (adjust to VM public IP / DNS)
KEYCLOAK_URL=http://<VM_PUBLIC_IP>:8080
OIDC_ISSUER=http://<VM_PUBLIC_IP>:8080/realms/master

# oauth2-proxy (random long string in real use)
OAUTH2_PROXY_COOKIE_SECRET=change_me_32bytes_base64
OAUTH2_PROXY_CLIENT_ID=nginx
OAUTH2_PROXY_CLIENT_SECRET=change_me